{
  "name": "@lc-agent/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./app": {
      "types": "./src/app.ts",
      "import": "./src/app.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./desktop/runtime": {
      "types": "./src/desktop/runtime.ts",
      "import": "./src/desktop/runtime.ts"
    }
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "typecheck": "tsc --noEmit --incremental --tsBuildInfoFile ../../.cache/tsc/agent-api.tsbuildinfo"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
